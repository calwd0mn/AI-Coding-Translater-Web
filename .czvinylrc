{
  "headerFormat": "{type}: {subject}",
  "commitTypes": [
    {
      "value": "feat",
      "description": "新增功能"
    },
    {
      "value": "fix",
      "description": "修复问题"
    },
    {
      "value": "docs",
      "description": "文档更新"
    },
    {
      "value": "style",
      "description": "代码格式调整，不影响逻辑"
    },
    {
      "value": "refactor",
      "description": "代码重构，不新增功能也不修复问题"
    },
    {
      "value": "perf",
      "description": "性能优化"
    },
    {
      "value": "test",
      "description": "测试相关修改"
    },
    {
      "value": "build",
      "description": "构建或依赖相关修改"
    },
    {
      "value": "ci",
      "description": "持续集成配置修改"
    },
    {
      "value": "chore",
      "description": "杂项调整或辅助工具修改"
    },
    {
      "value": "revert",
      "description": "回滚提交"
    }
  ],
  "typeQuestion": "请选择本次提交的类型：\n",
  "scopeQuestion": "请输入影响范围，例如模块名或页面名：",
  "skipScope": true,
  "ticketIdQuestion": "请输入关联任务编号，如无可直接跳过：",
  "skipTicketId": true,
  "subjectQuestion": "请简要描述本次更改：\n",
  "subjectMaxLength": 90,
  "subjectMinLength": 1,
  "bodyQuestion": "如需补充更详细说明，请输入多行描述：\n",
  "skipBody": true,
  "skipBreakingChanges": true,
  "issuesQuestion": "请输入关联 issue，例如 #123：",
  "skipIssues": true
}
